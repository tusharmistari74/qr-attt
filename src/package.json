    "html5-qrcode": "^2.3.8",
    "@types/qrcode": "^1.5.2",
    "motion": "^10.16.0",
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "vite": "^4.4.5",
    "vite-plugin-pwa": "^0.16.4",
    "typescript": "^5.0.2"
  }
}